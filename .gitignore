# ============================================================
# Security baseline (SSOT: _meta/_templates/infra/gitignore-security-baseline.md)
# ============================================================

# --- Secret insurance (STD-00020 R3) ---
**/.env
**/.env.local
**/.env.*.local
**/.envrc
**/.envrc.local

**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.jks
**/*.keystore
**/*.gpg

**/id_rsa
**/id_rsa.*
**/id_dsa
**/id_ecdsa
**/id_ecdsa.*
**/id_ed25519
**/id_ed25519.*

**/credentials
**/credentials.json
**/credentials.yaml
**/credentials.yml
**/*.credentials.json
**/.git-credentials
**/.netrc
**/.npmrc
**/.pgpass
**/.htpasswd
**/.vault_pass
**/vault_pass.txt

**/service_account*.json
**/*-service-account*.json
**/firebase-adminsdk*.json
**/gcp-credentials*.json
**/aws-credentials*.json
**/client_secret*.json

**/secret.yaml
**/secret.yml
**/secrets.yaml
**/secrets.yml
**/private.asc
**/privkey.asc
**/secret.asc

**/.aws/config
**/.config/gcloud/application_default_credentials.json
**/.config/gcloud/credentials.db
**/.credentials/
**/sensitive/
**/kubeconfig
**/*.kubeconfig

# --- OS generated files ---
**/.DS_Store
**/.DS_Store?
**/._*
**/.Spotlight-V100
**/.Trashes
**/Thumbs.db
**/ehthumbs.db
**/Desktop.ini

# --- Editor / IDE ---
**/.vscode/
**/.idea/
**/*.swp
**/*.swo
**/*~
**/.project
**/.classpath
**/.settings/

# --- Node.js / TypeScript ---
**/node_modules/
**/.npm/
**/*.tsbuildinfo
**/.eslintcache

# --- Python ---
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.egg-info/
**/.mypy_cache/
**/.ruff_cache/
**/.pytest_cache/
**/venv/
**/.venv/

# --- Build output / coverage ---
**/dist/
**/coverage/
**/.nyc_output/

# --- Logs / temp files ---
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/*.tmp
**/*.temp

# ============================================================
# Project-specific exclusions (add below)
# ============================================================

# VS Code workspace configs (intentionally tracked for extension development)
!extensions/*/.vscode/

# Build output
out/

# VS Code extension packages
*.vsix

# VS Code test downloads
.vscode-test/
