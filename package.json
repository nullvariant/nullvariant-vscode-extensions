{
  "name": "nullvariant-vscode-extensions",
  "version": "0.0.0",
  "private": true,
  "description": "VS Code extensions monorepo",
  "author": "Null;Variant <null@nullvariant.com>",
  "license": "MIT",
  "workspaces": [
    "extensions/*"
  ],
  "scripts": {
    "prepare": "husky || true",
    "lint:all": "npm run lint --workspaces --if-present",
    "test:all": "npm run test --workspaces --if-present",
    "compile:all": "npm run compile --workspaces --if-present",
    "watch:all": "npm run watch --workspaces --if-present"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.3"
  },
  "overrides": {
    "brace-expansion@1": "^1.1.13",
    "brace-expansion@2": "^2.0.3",
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5",
    "yauzl": "^3.2.1"
  },
  "lint-staged": {
    "*.md": "prettier --write"
  }
}
